<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>PodBlendz – Search</title>

  <style>
    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      background: #070b10;
      color: #e8edf3;
    }

    header {
      padding: 1.5rem;
      border-bottom: 1px solid #1f2933;
      background: #0b1220;
    }

    main {
      max-width: 960px;
      margin: 0 auto;
      padding: 2rem 1.25rem;
    }

    .results {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1rem;
    }

    .card {
      background: #ffffff;
      color: #111;
      padding: 1rem;
      border-radius: 8px;
    }
  </style>
</head>
<body>

<header>
  <h1>Search Results</h1>
  <p id="subtitle"></p>
</header>

<main>
  <div id="results" class="results"></div>
</main>

<script>
  const params = new URLSearchParams(window.location.search);
  const q = params.get("q");

  const subtitle = document.getElementById("subtitle");
  const resultsEl = document.getElementById("results");

  if (!q) {
    subtitle.textContent = "No search query.";
  } else {
    subtitle.textContent = `Results for “${q}”`;
    fetch(`/rss/search?q=${encodeURIComponent(q)}`)
      .then(r => r.json())
      .then(data => {
        const results = data.results || [];
        if (!results.length) {
          resultsEl.innerHTML = "<p>No results.</p>";
          return;
        }
        resultsEl.innerHTML = results.map(r => `
          <div class="card">
            <strong>${r.title}</strong><br/>
            <small>${r.source || ""}</small>
          </div>
        `).join("");
      })
      .catch(err => {
        resultsEl.innerHTML = "<p>Error loading results.</p>";
        console.error(err);
      });
  }
</script>

</body>
</html>